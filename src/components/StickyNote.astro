---
const { children } = Astro.props;
---

<style>
    .sticky {
        position: relative;
        width: min(300px, 88vw);
        aspect-ratio: 1 / 1;
        background-color: #fef08a;
        background-image: repeating-linear-gradient(
            0deg,
            transparent,
            transparent 27px,
            rgba(150, 150, 100, 0.25) 27px,
            rgba(150, 150, 100, 0.25) 28px
        );
        padding: clamp(16px, 6%, 24px);
        transform: rotate(-2deg);
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.08);
        font-family: 'Roboto Serif'
    }

    /* Soft shadow across the top adhesive strip */
    .sticky::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 35%;
        background: linear-gradient(
            180deg,
            rgba(0, 0, 0, 0.13) 0%,
            rgba(0, 0, 0, 0.05) 50%,
            rgba(0, 0, 0, 0.01) 100%
        );
        pointer-events: none;
    }

    .sticky::after {
        content: "";
        position: absolute;
        inset: 0;
        z-index: -1;
        background: transparent;
        box-shadow:
            0px 8px 4px -2px rgba(0, 0, 0, 0.06),
            0px 20px 8px -4px rgba(0, 0, 0, 0.1),
            0px 38px 12px -4px rgba(0, 0, 0, 0.13),
            0px 55px 14px -2px rgba(0, 0, 0, 0.12),
            0px 70px 16px 0px rgba(0, 0, 0, 0.1);
    }

    .lines {
        display: flex;
        flex-direction: column;
    }

    .line {
        height: 28px;
        line-height: 28px;
        font-size: clamp(0.85rem, 3.5vw, 1.35rem);
        color: #333;
    }

    .line:nth-child(1) {
        color: #2a2a2a;
        font-size: clamp(0.95rem, 4vw, 1.45rem);
        font-weight: 600;
    }
    .line:nth-child(3) {
        color: #404040;
    }
    .line:nth-child(4) {
        color: #383838;
        transform: rotate(0.3deg);
    }
    .line:nth-child(5) {
        color: #2e2e2e;
    }
    .line:nth-child(6) {
        color: #3c3c3c;
        transform: rotate(-0.2deg);
    }

    .blank {
        visibility: hidden;
    }
</style>

<div class="sticky">
    <div class="lines">
        <div class="line">now</div>
        <div class="line blank">x</div>
        <div class="line">— line 1</div>
        <div class="line">— line 2</div>
        <div class="line">— line 3</div>
    </div>
</div>
