---
const currentPath = Astro.url.pathname;

import "../styles/navbar.css";
---

<nav class="navbar">
    <ul id="tabs">
        <li class={currentPath === "/" ? "current" : ""}>
            <a href="/">About</a>
        </li>
        <li class={currentPath === "/now" ? "current" : ""}>
            <a href="/now">Now</a>
        </li>
        <li class={currentPath === "/projects" ? "current" : ""}>
            <a href="/projects">Projects</a>
        </li>

        <div class="mobile-menu" id="mobile-menu">
            <a href="/" class={currentPath === "/" ? "current" : ""}>About</a>
            <a href="/now" class={currentPath === "/now" ? "current" : ""}
                >Now</a
            >
            <a
                href="/projects"
                class={currentPath === "/projects" ? "current" : ""}>Projects</a
            >
        </div>

        <div class="clip-wrapper">
            <img
                src="/graphics/paperclip.png"
                alt="paperclip"
                id="navbar-clip"
            />
            <div class="clip-cover-right-top"></div>
            <div class="clip-cover-right-bottom"></div>
            <div class="clip-cover-left-top"></div>
            <div class="clip-cover-left-bottom"></div>
            <!-- sits on top, hides parts of the image -->
        </div>
    </ul>
</nav>

<script>
    import { navigate } from "astro:transitions/client";

    function closeMenu() {
        const clip = document.getElementById("navbar-clip");
        const menu = document.getElementById("mobile-menu");
        const container = document.querySelector(".container");

        clip?.classList.remove("pushed");
        menu?.classList.remove("open");
        document.body.classList.remove("menu-open");
        container?.classList.remove("hidden");
    }

    document.addEventListener("astro:page-load", () => {
        const clip = document.getElementById("navbar-clip")!;
        const menu = document.getElementById("mobile-menu")!;
        const navbar = document.querySelector(".navbar")!;
        const container = document.querySelector(".container")!;

        // if (!clip || !menu || !navbar) return;

        function setMenuPosition() {
            const navBottom = navbar.getBoundingClientRect().bottom;
            document.documentElement.style.setProperty(
                "--nav-bottom",
                `${navBottom}px`,
            );
        }

        setMenuPosition();
        window.addEventListener("resize", setMenuPosition);
        window.addEventListener("resize", () => {
            if (window.innerWidth > 900) closeMenu();
        });

        // Clip toggle — guard against duplicate listeners on the persisted element
        if (!clip.dataset.listenerAttached) {
            clip.dataset.listenerAttached = "true";
            clip.addEventListener("click", () => {
                // const menu = document.getElementById("mobile-menu");
                // const container = document.querySelector(".container");
                // const navbar = document.querySelector(".navbar");
                const navBottom = navbar.getBoundingClientRect().bottom;
                document.documentElement.style.setProperty(
                    "--nav-bottom",
                    `${navBottom}px`,
                );
                clip.classList.toggle("pushed");
                menu?.classList.toggle("open");
                document.body.classList.toggle("menu-open");
                container?.classList.toggle("hidden");
            });
        }

        menu.querySelectorAll("a").forEach((link) => {
            link.addEventListener("click", (e) => {
                e.preventDefault();
                const href = link.getAttribute("href");
                if (!href) return;

                // Freeze position as inline style, remove class (no visual change)
                clip.style.transform = "translate(5px, -14.4px)";
                clip.classList.remove("pushed");

                menu?.classList.remove("open");
                document.body.classList.remove("menu-open");
                container?.classList.remove("hidden");

                navigate(href);
            });
        });

        document.addEventListener("astro:after-swap", () => {
            const clip = document.getElementById("navbar-clip");
            if (!clip) return;

            clip.style.transform = "translate(5px, -14.4px)";
            clip.getBoundingClientRect(); // force the browser to commit the pushed state
            clip.style.transform = ""; // now transition plays smoothly from there
        });
    });
</script>
