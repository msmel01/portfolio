---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { ClientRouter, fade } from "astro:transitions";
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link
      href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css"
      rel="stylesheet"
    />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="">
    <Navbar transition:persist="navbar" />
    <div class="container">
      <div class="content-container" transition:animate="none">
        <slot />
      </div>
      <!-- <Footer /> -->
    </div>
  </body>
</html>

<script>
  import { setupAnnotations } from "../scripts/globalAnnotations";

  // astro:page-load fires on both first load and every client-side navigation.
  document.addEventListener("astro:page-load", () => {
    // Wait for fonts so element dimensions are final before measuring SVG positions.
    // rAF inside ensures the browser has painted at least one frame first.
    const run = () => requestAnimationFrame(() => setupAnnotations());
    if (document.fonts?.ready) {
      document.fonts.ready.then(run);
    } else {
      setTimeout(run, 150);
    }
  });
</script>

<style>
  .container {
    border-left: 1px solid #ccc;
    border-right: 1px solid #ccc;
    border-bottom: 1px solid #ccc;
    padding-top: 3em;
    min-height: 100vh;
    background: #fff;
    max-width: calc(100% - 2em);
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 0.5em;
  }
  .content-container {
    margin-left: auto;
    margin-right: auto;
    max-width: 1000px;
    padding: 1em;
  }

  .container.hidden {
    visibility: hidden;
  }
</style>
